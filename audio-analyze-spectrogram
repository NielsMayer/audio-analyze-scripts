#!/usr/bin/env bash
# audio-analyze-spectrogram — Log-frequency spectrogram
# Usage: audio-analyze-spectrogram <mediafile>
# Output: JSON to stdout

set -euo pipefail

MEDIAFILE="${1:-}"
if [[ -z "$MEDIAFILE" ]]; then
    echo "Usage: $0 <mediafile>" >&2
    exit 1
fi

N_BINS="${SPECTROGRAM_BINS:-256}"
N_FRAMES="${SPECTROGRAM_FRAMES:-512}"
FFT_SIZE="${SPECTROGRAM_FFT:-2048}"
HOP="${SPECTROGRAM_HOP:-512}"

echo "Computing spectrogram (this may take a moment)..." >&2

python3 -c "
import sys, subprocess, json, math
import numpy as np
from scipy import signal

mediafile = sys.argv[1]
n_bins = int(sys.argv[2])
n_frames_target = int(sys.argv[3])
fft_size = int(sys.argv[4])
hop = int(sys.argv[5])

# Get audio info
probe = subprocess.run(['ffprobe','-v','quiet','-print_format','json','-show_streams',mediafile], capture_output=True, text=True)
info = json.loads(probe.stdout)
audio_stream = next(s for s in info['streams'] if s['codec_type']=='audio')
sr = int(audio_stream['sample_rate'])

# Extract audio: mono float32
pcm = subprocess.run([
    'ffmpeg','-hide_banner','-v','quiet',
    '-i',mediafile,
    '-map','0:a:0',
    '-ac','1',
    '-af','aresample=async=1:first_pts=0,aformat=sample_fmts=flt',
    '-ar',str(sr),
    '-f','f32le','-'
], capture_output=True)

if len(pcm.stdout) == 0:
    print('Error: no audio data extracted', file=sys.stderr)
    sys.exit(1)

samples = np.frombuffer(pcm.stdout, dtype=np.float32)
peak = np.max(np.abs(samples))
print(f'Extracted {len(samples)} samples, peak amplitude {peak:.6f}', file=sys.stderr)

if peak < 1e-10:
    print('Error: extracted audio is silent', file=sys.stderr)
    sys.exit(1)

# Compute spectrogram using scipy (properly normalized STFT)
# scaling='spectrum', mode='magnitude' gives the magnitude spectrum
# For a sine wave of amplitude A at an FFT bin center, peak magnitude = A/2
# We multiply by 2 to get amplitude relative to full scale
freqs, times_s, Sxx = signal.spectrogram(
    samples, sr,
    nperseg=fft_size,
    noverlap=fft_size - hop,
    window='hann',
    scaling='spectrum',
    mode='magnitude'
)

# Correct for scipy's normalization (peak of sine wave = amplitude/2)
Sxx = Sxx * 2

# Limit to target number of frames
if len(times_s) > n_frames_target:
    Sxx = Sxx[:, :n_frames_target]
    times_s = times_s[:n_frames_target]

# Create log-spaced frequency bins
nyquist = sr / 2.0
freq_min = 20.0
freq_max = nyquist
log_freqs = np.logspace(np.log10(freq_min), np.log10(freq_max), n_bins)

# Interpolate spectrogram to log-frequency bins
# scipy spectrogram already has energy across all bins due to windowing,
# so interpolation works correctly (unlike raw FFT magnitude interpolation)
log_spec = np.zeros((n_bins, len(times_s)))
for i in range(len(times_s)):
    log_spec[:, i] = np.interp(
        log_freqs,
        freqs,
        Sxx[:, i],
        left=Sxx[0, i],
        right=Sxx[-1, i]
    )

# Convert to dB (reference = 1.0 = 0 dBFS)
db_spec = 20.0 * np.log10(np.maximum(log_spec, 1e-12))
db_spec = np.maximum(db_spec, -140.0)

# Debug stats
print(f'Spectrogram shape: {db_spec.shape}, dB range: {np.min(db_spec):.1f} to {np.max(db_spec):.1f}', file=sys.stderr)

# Build output
reassigned = []
for i in range(len(times_s)):
    reassigned.append({
        'time': round(float(times_s[i]), 4),
        'magnitudes': db_spec[:, i].tolist()
    })

result = {
    'file': mediafile,
    'sampleRate': sr,
    'durationSeconds': round(len(samples) / sr, 4),
    'fftSize': fft_size,
    'hopSize': hop,
    'frequencyBins': n_bins,
    'timeFrames': len(reassigned),
    'frequencyRangeHz': [round(freq_min, 1), round(freq_max, 1)],
    'frequenciesHz': [round(float(f), 1) for f in log_freqs.tolist()],
    'timesSeconds': [round(float(t), 4) for t in times_s.tolist()],
    'spectrogram': reassigned
}

json.dump(result, sys.stdout, indent=2)
" "$MEDIAFILE" "$N_BINS" "$N_FRAMES" "$FFT_SIZE" "$HOP"
